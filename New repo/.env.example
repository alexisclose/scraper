# Logging — pino level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info
# Set to "1" for pretty-printed logs in dev (default in non-prod NODE_ENV)
LOG_PRETTY=

# Tesla scraper — Chrome DevTools Protocol bridge
TESLA_CDP_PORT=9223
# Override the auto-detected Chrome / Edge / Brave path if needed
TESLA_CHROME=

# VW scraper — set to "1" to skip the on-disk slug-discovery cache
VW_NO_CACHE=

# HTTP fetcher
HTTP_TIMEOUT_MS=20000
HTTP_MAX_RETRIES=3
HTTP_CONCURRENCY=8

# Output directory roots (defaults shown)
DATA_DIR=./data
